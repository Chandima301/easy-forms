{
	"name": "@easy-forms/shadcn",
	"version": "0.1.0",
	"description": "Default renderer registry for @easy-forms/core — shadcn-style components built on Radix UI + Tailwind.",
	"license": "MIT",
	"author": "Easy Forms",
	"homepage": "https://github.com/Chandima301/easy-forms#readme",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/Chandima301/easy-forms.git",
		"directory": "packages/shadcn"
	},
	"bugs": {
		"url": "https://github.com/Chandima301/easy-forms/issues"
	},
	"keywords": [
		"react",
		"form",
		"forms",
		"shadcn",
		"radix",
		"tailwind",
		"renderer",
		"easy-forms",
		"ui",
		"typescript"
	],
	"publishConfig": {
		"access": "public"
	},
	"sideEffects": ["**/*.css"],
	"type": "module",
	"main": "./dist/index.cjs",
	"module": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js",
			"require": "./dist/index.cjs"
		},
		"./styles.css": "./styles.css",
		"./package.json": "./package.json"
	},
	"files": ["dist", "styles.css", "README.md", "LICENSE"],
	"scripts": {
		"build": "tsup",
		"dev": "tsup --watch",
		"test": "vitest run --passWithNoTests",
		"test:watch": "vitest",
		"typecheck": "tsc --noEmit",
		"clean": "rimraf dist .turbo"
	},
	"dependencies": {
		"@radix-ui/react-checkbox": "^1.1.2",
		"@radix-ui/react-label": "^2.1.0",
		"@radix-ui/react-popover": "^1.1.2",
		"@radix-ui/react-radio-group": "^1.2.1",
		"@radix-ui/react-select": "^2.1.2",
		"@radix-ui/react-slot": "^1.1.0",
		"class-variance-authority": "^0.7.0",
		"clsx": "^2.1.1",
		"lucide-react": "^0.460.0",
		"tailwind-merge": "^2.5.4"
	},
	"peerDependencies": {
		"@easy-forms/core": "workspace:^",
		"react": ">=18.0.0",
		"react-dom": ">=18.0.0",
		"tailwindcss": ">=3.4.0"
	},
	"devDependencies": {
		"@easy-forms/core": "workspace:*",
		"@types/react": "^18.3.12",
		"@types/react-dom": "^18.3.1",
		"react": "^18.3.1",
		"react-dom": "^18.3.1",
		"rimraf": "^6.0.1",
		"tsup": "^8.3.5",
		"typescript": "^5.6.3",
		"vitest": "^2.1.5"
	}
}
