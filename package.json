{
	"name": "easy-forms-workspace",
	"version": "0.0.0",
	"private": true,
	"description": "easy-forms monorepo — a higher-level React form library driven by a question-object schema.",
	"packageManager": "pnpm@9.0.0",
	"engines": {
		"node": ">=20"
	},
	"scripts": {
		"build": "turbo run build --filter=!docs",
		"test": "turbo run test",
		"lint": "biome check .",
		"format": "biome format --write .",
		"typecheck": "turbo run typecheck --filter=!docs",
		"dev": "turbo run dev --parallel --filter=!docs",
		"clean": "turbo run clean && rimraf node_modules",
		"changeset": "changeset",
		"version": "changeset version",
		"release": "turbo run build && changeset publish"
	},
	"devDependencies": {
		"@biomejs/biome": "^1.9.4",
		"@changesets/cli": "^2.27.9",
		"rimraf": "^6.0.1",
		"turbo": "^2.3.0",
		"typescript": "^5.6.3"
	}
}
